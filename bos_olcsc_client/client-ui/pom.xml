                            <includes>
                                <include>web.xml</include>
                            </includes>
                            <targetPath>WEB-INF</targetPath>
                            <filtering>true</filtering>
                        </webResource>
                    </webResources>
				 
				</configuration>
			</plugin>


            <!--  Make the test class available for deployment -->
