			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-war-plugin</artifactId>
				<configuration>
					<attachClasses>true</attachClasses>
					  <!--  weblogic upgrade changes 
						<excludes>
                        			<exclude>**/test/**</exclude>
                    				</excludes>-->
					<webResources>
                        <webResource>
