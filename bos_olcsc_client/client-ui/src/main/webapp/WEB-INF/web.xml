    <filter>
        <filter-name>CSSFilter</filter-name>
        <filter-class>com.etcc.csc.filter.CSSFilter</filter-class>
        <init-param>
          <param-name>Character1</param-name>
          <param-value>--</param-value>
        </init-param>
        <init-param>
          <!-- less-than sign [ < ] -->
          <param-name>Character2</param-name>
          <param-value>&#60;</param-value>
        </init-param>
         <init-param>
          <!-- greater-than sign [ > ] -->
          <param-name>Character3</param-name>
          <param-value>&#62;</param-value>
        </init-param>
         <init-param>
          <!-- quotation mark [ " ] -->
          <param-name>Character4</param-name>
          <param-value>&#34;</param-value>
        </init-param>
        <init-param>
          <!-- apostrophe [ ' ] -->
          <param-name>Character5</param-name>
          <param-value>&#39;</param-value>
        </init-param>
         <init-param>
          <!-- left-parenthesis [ ( ] -->
          <param-name>Character6</param-name>
          <param-value>&#40;</param-value>
        </init-param>
          <init-param>
          <!-- right-parenthesis [ ) ] -->
          <param-name>Character7</param-name>
          <param-value>&#41;</param-value>
        </init-param>
         <init-param>
          <!-- grave accent [ ` ] -->
          <param-name>Character8</param-name>
          <param-value>&#96;</param-value>
        </init-param>
        <init-param>
          <param-name>RedirectPage</param-name>
          <param-value>/cssError.do</param-value>
        </init-param>
    </filter>

