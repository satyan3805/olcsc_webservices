			<url>https://nexus01.etcc.com/repository/maven-rite-internal/</url>
		</repository>		
		<repository>
			<id>Nexus repository -- maven-proprietary</id>
			<url>https://nexus01.etcc.com/repository/maven-proprietary/</url>
		</repository>
		<repository>
            <id>central</id>
            <url>https://nexus01.etcc.com/repository/maven-apache/</url>
		</repository>
	</repositories>	
	<pluginRepositories>
		<pluginRepository>
			<id>central</id>
			<url>https://nexus01.etcc.com/repository/maven-apache/</url>
		</pluginRepository>
	</pluginRepositories>
</project>
